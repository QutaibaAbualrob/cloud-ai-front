# CloudAI Frontend — Environment Configuration
# Copy this file to .env and fill in values for local dev.
# For Vercel, set these in Project Settings → Environment Variables.
# Only VITE_* prefixed vars are exposed to the client bundle.

# Backend API base URL (Django DRF backend)
VITE_API_BASE=http://localhost:8000/api

# Google OAuth Client ID for social login
# Get from Google Cloud Console → APIs & Services → Credentials
# Must match the one in backend .env's GOOGLE_OAUTH2_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
